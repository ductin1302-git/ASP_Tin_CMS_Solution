@model IEnumerable<CMS.Data.Entities.Category>
@{
    ViewData["Title"] = "Danh mục bài viết";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">📂 Danh Mục Bài Viết</h1>
        <p class="page-subtitle">Phân loại nội dung tin tức thể thao</p>
    </div>
    <a asp-action="Create" class="btn-sport btn-primary-sport">
        <i class="bi bi-plus-lg"></i> Thêm danh mục
    </a>
</div>

<div class="data-card">
    <div class="data-card-header">
        <div class="data-card-title">
            <span class="title-icon"><i class="bi bi-folder2-open"></i></span>
            Tất cả danh mục
            <span class="badge-admin badge-primary" style="margin-left:6px;">@Model.Count() danh mục</span>
        </div>
    </div>
    <div style="overflow-x:auto;">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <span class="empty-state-icon">📂</span>
                <div class="empty-state-title">Chưa có danh mục nào</div>
                <div class="empty-state-text">Tạo danh mục để phân loại bài viết</div>
                <a asp-action="Create" class="btn-sport btn-primary-sport" style="margin-top:16px;display:inline-flex;">
                    <i class="bi bi-plus-lg"></i> Tạo ngay
                </a>
            </div>
        }
        else
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        string[] emojis = { "⚽", "🏀", "🎾", "🏃", "🏋️", "🚴", "🏊", "🥊" };
                        int i = 0;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="id-pill">#@item.Id</span></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,107,53,0.12);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;">
                                        @emojis[i % emojis.Length]
                                    </div>
                                    <span style="color:var(--text-primary);font-weight:600;">@item.Name</span>
                                </div>
                            </td>
                            <td style="max-width:280px;">
                                <span style="font-size:13px;color:var(--text-muted);display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @(string.IsNullOrEmpty(item.Description) ? "—" : item.Description)
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-warning-sport" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn-icon btn-danger-sport" title="Xóa"
                                       onclick="return confirm('Xóa danh mục «@item.Name»?')">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        }
    </div>
</div>
