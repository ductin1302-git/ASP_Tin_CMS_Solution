@model CMS.Data.Entities.Category
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">✏️ Chỉnh Sửa Danh Mục</h1>
        <p class="page-subtitle">@Model.Name</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" style="max-width:560px;">
    <input type="hidden" asp-for="Id" />
    <div class="form-card">
        <div class="form-card-header">
            <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">📂</div>
            <span class="form-card-title" style="font-size:14px;">Thông tin danh mục</span>
        </div>
        <div class="form-card-body">
            <div class="form-group-admin">
                <label class="form-label-admin">Tên danh mục <span style="color:var(--danger)">*</span></label>
                <input asp-for="Name" class="form-control-admin" placeholder="VD: Tin bóng đá..." />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>
            <div class="form-group-admin">
                <label class="form-label-admin">Mô tả</label>
                <textarea asp-for="Description" class="form-control-admin" rows="3"
                          placeholder="Mô tả ngắn về danh mục..."></textarea>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-sport btn-warning-sport">
                    <i class="bi bi-check-lg"></i> Cập nhật
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>
