@model CMS.Data.Entities.Customer
@{
    ViewData["Title"] = "Cập nhật khách hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">✏️ Cập Nhật Khách Hàng</h1>
        <p class="page-subtitle">@Model.FullName</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" style="max-width:680px;">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Password" />

    <div class="form-card">
        <div class="form-card-header">
            <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">👥</div>
            <span class="form-card-title" style="font-size:14px;">Thông tin khách hàng</span>
        </div>
        <div class="form-card-body">
            <div class="form-section-title">Thông tin cá nhân</div>
            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Họ và tên <span style="color:var(--danger)">*</span></label>
                    <input asp-for="FullName" class="form-control-admin" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Email <span style="color:var(--danger)">*</span></label>
                    <input asp-for="Email" type="email" class="form-control-admin" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control-admin" placeholder="0901234567" />
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Mật khẩu mới (để trống = giữ nguyên)</label>
                    <input name="NewPassword" type="password" class="form-control-admin" placeholder="Nhập mật khẩu mới nếu muốn đổi..." />
                </div>
            </div>
            <div class="form-group-admin">
                <label class="form-label-admin">Địa chỉ giao hàng</label>
                <textarea asp-for="Address" class="form-control-admin" rows="2" placeholder="Địa chỉ..."></textarea>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-sport btn-warning-sport">
                    <i class="bi bi-check-lg"></i> Cập nhật
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>
