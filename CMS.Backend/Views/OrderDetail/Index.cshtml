@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    ViewData["Title"] = "Quản lý Chi tiết Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Chi tiết Đơn hàng</h6>
        <a asp-action="Create" class="btn btn-primary btn-sm">Thêm mới</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Mã Đơn hàng</th>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><a asp-controller="Order" asp-action="Edit" asp-route-id="@item.OrderId">#@item.OrderId</a></td>
                            <td>@(item.Product != null ? item.Product.Name : "N/A")</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                            <td class="font-weight-bold text-danger">@((item.Quantity * item.UnitPrice).ToString("N0")) VNĐ</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa chi tiết này?');">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
