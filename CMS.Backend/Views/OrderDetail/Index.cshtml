@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    ViewData["Title"] = "Quản lý Chi tiết Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">Chi tiết Đơn hàng</h1>
    </div>
</div>

<div class="data-card mb-4">
    <div class="data-card-header d-flex justify-content-between align-items-center">
        <div class="data-card-title">
            <span class="title-icon"><i class="bi bi-receipt"></i></span>
            Danh sách Chi tiết Đơn hàng
        </div>
        <a asp-action="Create" class="btn-sport btn-primary-sport">
            <i class="bi bi-plus-lg"></i> Thêm mới
        </a>
    </div>
    <div style="overflow-x:auto;">
        <table class="admin-table" width="100%" cellspacing="0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Mã Đơn hàng</th>
                    <th>Sản phẩm</th>
                    <th>Số lượng</th>
                    <th>Đơn giá</th>
                    <th>Thành tiền</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="id-pill">#@item.Id</span></td>
                        <td><a asp-controller="Order" asp-action="Edit" asp-route-id="@item.OrderId" class="badge-admin badge-primary">#@item.OrderId</a></td>
                        <td style="color:var(--text-primary);font-weight:600;">@(item.Product != null ? item.Product.Name : "N/A")</td>
                        <td>@item.Quantity</td>
                        <td class="price-text">@item.UnitPrice.ToString("N0") đ</td>
                        <td class="price-text" style="color:var(--danger);">@((item.Quantity * item.UnitPrice).ToString("N0")) đ</td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-warning-sport" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon btn-danger-sport" onclick="return confirm('Bạn có chắc chắn muốn xóa chi tiết này?');" title="Xóa">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

