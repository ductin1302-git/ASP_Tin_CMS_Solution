@model CMS.Data.Entities.OrderDetail
@{
    ViewData["Title"] = "Thêm Chi tiết Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">Thêm Chi tiết Đơn hàng</h1>
    </div>
</div>

<div class="form-card mb-4">
    <div class="form-card-header">
        <h6 class="form-card-title"><i class="bi bi-cart-plus text-primary"></i> Thêm Chi tiết Đơn hàng</h6>
    </div>
    <div class="form-card-body">
        <form asp-action="Create" method="post">
            <div class="form-row">
                <div class="form-group-admin">
                    <label asp-for="OrderId" class="form-label-admin">Mã Đơn hàng <span class="text-danger">*</span></label>
                    <select asp-for="OrderId" class="form-control-admin" asp-items="ViewBag.OrderList">
                        <option value="">-- Chọn đơn hàng --</option>
                    </select>
                    <span asp-validation-for="OrderId" class="text-danger"></span>
                </div>
                <div class="form-group-admin">
                    <label asp-for="ProductId" class="form-label-admin">Sản phẩm <span class="text-danger">*</span></label>
                    <select asp-for="ProductId" class="form-control-admin" asp-items="ViewBag.ProductList">
                        <option value="">-- Chọn sản phẩm --</option>
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger"></span>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group-admin">
                    <label asp-for="Quantity" class="form-label-admin">Số lượng <span class="text-danger">*</span></label>
                    <input asp-for="Quantity" type="number" class="form-control-admin" min="1" value="1" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="form-group-admin">
                    <label asp-for="UnitPrice" class="form-label-admin">Đơn giá tại thời điểm mua <span class="text-danger">*</span></label>
                    <input asp-for="UnitPrice" type="number" class="form-control-admin" min="0" value="0" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-primary-sport">
                    <i class="bi bi-save2"></i> Lưu lại
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

