@model CMS.Data.Entities.OrderDetail
@{
    ViewData["Title"] = "Thêm Chi tiết Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thêm Chi tiết Đơn hàng</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="OrderId">Mã Đơn hàng <span class="text-danger">*</span></label>
                    <select asp-for="OrderId" class="form-control" asp-items="ViewBag.OrderList">
                        <option value="">-- Chọn đơn hàng --</option>
                    </select>
                    <span asp-validation-for="OrderId" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="ProductId">Sản phẩm <span class="text-danger">*</span></label>
                    <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductList">
                        <option value="">-- Chọn sản phẩm --</option>
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Quantity">Số lượng <span class="text-danger">*</span></label>
                    <input asp-for="Quantity" type="number" class="form-control" min="1" value="1" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="UnitPrice">Đơn giá tại thời điểm mua <span class="text-danger">*</span></label>
                    <input asp-for="UnitPrice" type="number" class="form-control" min="0" value="0" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-success">Lưu lại</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>
