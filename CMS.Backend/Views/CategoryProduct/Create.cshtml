@model CMS.Data.Entities.CategoryProduct
@{
    ViewData["Title"] = "Thêm Danh mục Sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">Thêm Danh mục Sản phẩm</h1>
    </div>
</div>

<div class="form-card mb-4">
    <div class="form-card-header">
        <h6 class="form-card-title"><i class="bi bi-folder-plus text-primary"></i> Khởi tạo Danh mục Sản phẩm</h6>
    </div>
    <div class="form-card-body">
        <form asp-action="Create" method="post">
            <div class="form-group-admin">
                <label asp-for="Name" class="form-label-admin">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control-admin" placeholder="Nhập tên danh mục thể thao..." required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="form-group-admin">
                <label asp-for="Description" class="form-label-admin">Mô tả danh mục</label>
                <textarea asp-for="Description" class="form-control-admin" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-primary-sport">
                    <i class="bi bi-save2"></i> Lưu Danh Mục
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

