@model CMS.Data.Entities.User
@{
    ViewData["Title"] = "Thêm tài khoản quản trị";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">➕ Thêm Tài Khoản Quản Trị</h1>
        <p class="page-subtitle">Tạo tài khoản nhân viên hệ thống</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Create" method="post" style="max-width:600px;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">🛡️</div>
            <span class="form-card-title" style="font-size:14px;">Thông tin tài khoản</span>
        </div>
        <div class="form-card-body">
            <div class="form-section-title">Thông tin đăng nhập</div>
            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Tên đăng nhập <span style="color:var(--danger)">*</span></label>
                    <input asp-for="Username" class="form-control-admin" placeholder="VD: admin_sport..." required />
                    <span asp-validation-for="Username" class="field-validation-error"></span>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Mật khẩu <span style="color:var(--danger)">*</span></label>
                    <input asp-for="PasswordHash" type="password" class="form-control-admin" required />
                </div>
            </div>

            <div class="form-section-title" style="margin-top:16px;">Thông tin cá nhân</div>
            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Họ và tên <span style="color:var(--danger)">*</span></label>
                    <input asp-for="FullName" class="form-control-admin" placeholder="Nguyễn Văn A..." required />
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Vai trò <span style="color:var(--danger)">*</span></label>
                    <select asp-for="Role" class="form-control-admin" required>
                        <option value="">-- Chọn vai trò --</option>
                        <option value="Admin">🛡️ Quản trị viên (Admin)</option>
                        <option value="Editor">✏️ Biên tập viên (Editor)</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-primary-sport">
                    <i class="bi bi-person-check"></i> Tạo tài khoản
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>
