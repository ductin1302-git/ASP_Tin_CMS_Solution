@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Danh sách Người dùng";
}

<div class="container mt-4">
    <h2>DANH SÁCH NGƯỜI DÙNG</h2>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tài khoản</th>
                <th>Họ tên</th>
                <th>Vai trò</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Username</td>
                    <td>@item.FullName</td>
                    <td>@item.Role</td>
                </tr>
            }
        </tbody>
    </table>
</div>
