@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản Lý Thành Viên";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">QUẢN LÝ THÀNH VIÊN</h2>
            <p class="text-muted small">Quản trị viên, biên tập viên và tác giả đóng góp nội dung hệ thống</p>
        </div>
        <button class="btn btn-success btn-sm px-3 rounded-pill shadow-sm">+ Thêm thành viên mới</button>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3" style="width: 80px;">ID</th>
                        <th class="py-3">Tên đăng nhập</th>
                        <th class="py-3">Họ và tên</th>
                        <th class="py-3" style="width: 180px;">Quyền hạn</th>
                        <th class="text-center py-3" style="width: 180px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold text-secondary">#@user.Id</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light text-success rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 38px; height: 38px; font-size: 0.95rem;">
                                        👤
                                    </div>
                                    <span class="fw-bold text-dark">@user.Username</span>
                                </div>
                            </td>
                            <td class="text-secondary fw-semibold">@user.FullName</td>
                            <td>
                                @if (user.Role == "Administrator")
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-1.5 fs-7">@user.Role</span>
                                }
                                else if (user.Role == "Editor")
                                {
                                    <span class="badge bg-info text-dark rounded-pill px-3 py-1.5 fs-7">@user.Role</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-1.5 fs-7">@user.Role</span>
                                }
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning me-1">Sửa</button>
                                <button class="btn btn-sm btn-outline-danger">Xóa</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
