@model CMS.Data.Entities.User
@{
    ViewData["Title"] = "Cập nhật quản trị viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">✏️ Cập Nhật Tài Khoản</h1>
        <p class="page-subtitle">@Model.Username</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" style="max-width:600px;">
    <input type="hidden" asp-for="Id" />
    <div class="form-card">
        <div class="form-card-header">
            <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">🛡️</div>
            <span class="form-card-title" style="font-size:14px;">Thông tin tài khoản</span>
        </div>
        <div class="form-card-body">
            <div class="form-section-title">Xác thực</div>
            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control-admin" readonly
                           style="opacity:0.6;cursor:not-allowed;" />
                    <div style="font-size:11px;color:var(--text-muted);margin-top:5px;">
                        <i class="bi bi-lock-fill"></i> Tên đăng nhập không thể thay đổi
                    </div>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Mật khẩu mới (để trống = giữ nguyên)</label>
                    <input type="password" name="NewPassword" class="form-control-admin"
                           placeholder="Nhập mật khẩu mới nếu muốn đổi..." />
                </div>
            </div>

            <div class="form-section-title" style="margin-top:16px;">Thông tin cá nhân</div>
            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Họ và tên <span style="color:var(--danger)">*</span></label>
                    <input asp-for="FullName" class="form-control-admin" required />
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Vai trò <span style="color:var(--danger)">*</span></label>
                    <select asp-for="Role" class="form-control-admin">
                        <option value="Admin">🛡️ Quản trị viên</option>
                        <option value="Editor">✏️ Biên tập viên</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-warning-sport">
                    <i class="bi bi-check-lg"></i> Cập nhật tài khoản
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>
