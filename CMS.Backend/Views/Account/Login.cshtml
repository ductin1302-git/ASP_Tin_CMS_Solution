@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập — SportZone Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

<div class="login-page">
    <!-- Animated background orbs -->
    <div class="login-bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>

    <!-- Animated grid bg from body::before already applied -->

    <div class="login-card">
        <!-- Card Top -->
        <div class="login-card-top">
            <div class="login-logo">🏆</div>
            <div class="login-title">SportZone Admin</div>
            <div class="login-subtitle">Hệ thống quản trị cửa hàng thể thao</div>
        </div>

        <!-- Card Body -->
        <div class="login-card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert-admin alert-danger-admin">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="login-input-group">
                    <i class="bi bi-person-fill login-input-icon"></i>
                    <input type="text"
                           name="username"
                           class="login-input"
                           placeholder="Tên đăng nhập"
                           required
                           autocomplete="username" />
                </div>

                <div class="login-input-group">
                    <i class="bi bi-lock-fill login-input-icon"></i>
                    <input type="password"
                           name="password"
                           class="login-input"
                           placeholder="Mật khẩu"
                           required
                           autocomplete="current-password" />
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-lightning-charge-fill"></i>
                    ĐĂNG NHẬP
                </button>
            </form>

            <div style="margin-top:24px; padding-top:20px; border-top:1px solid var(--border); text-align:center;">
                <p style="font-size:12px; color:var(--text-muted);">
                    <i class="bi bi-shield-check" style="color:var(--primary)"></i>
                    Chỉ dành cho quản trị viên được cấp quyền
                </p>
            </div>
        </div>
    </div>
</div>

</body>
</html>
