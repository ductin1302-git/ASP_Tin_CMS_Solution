@model CMS.Data.Entities.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    decimal totalAmount = 0;
    if (Model.OrderDetails != null)
    {
        totalAmount = Model.OrderDetails.Sum(od => od.Quantity * od.UnitPrice);
    }
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">📋 Đơn Hàng <span style="color:var(--primary)">#@Model.Id</span></h1>
        <p class="page-subtitle">Chi tiết đầy đủ đơn hàng</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<!-- Info + Status -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <!-- Customer info -->
    <div class="form-card" style="animation-delay:0s;">
        <div class="form-card-header">
            <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">👤</div>
            <span class="form-card-title" style="font-size:14px;">Thông tin khách hàng</span>
        </div>
        <div style="padding:20px;">
            <div class="details-grid" style="grid-template-columns:1fr 1fr;">
                <div class="detail-block">
                    <div class="detail-label">Khách hàng</div>
                    <div class="detail-value">@(Model.Customer?.FullName ?? "Khách vãng lai")</div>
                </div>
                <div class="detail-block">
                    <div class="detail-label">Email</div>
                    <div class="detail-value">@(Model.Customer?.Email ?? "—")</div>
                </div>
                <div class="detail-block">
                    <div class="detail-label">Điện thoại</div>
                    <div class="detail-value">@(Model.Customer?.Phone ?? "—")</div>
                </div>
                <div class="detail-block">
                    <div class="detail-label">Ngày đặt</div>
                    <div class="detail-value">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="detail-block" style="grid-column:1/-1;">
                        <div class="detail-label">Ghi chú</div>
                        <div class="detail-value">@Model.Notes</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Update status -->
    <div class="form-card" style="animation-delay:0.1s;">
        <div class="form-card-header">
            <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">🔄</div>
            <span class="form-card-title" style="font-size:14px;">Cập nhật trạng thái</span>
        </div>
        <div style="padding:20px;">
            <div style="margin-bottom:16px;">
                <div class="detail-label">Trạng thái hiện tại</div>
                <div style="margin-top:8px;">
                    @if (Model.Status == 0)
                    {
                        <span class="badge-admin order-status-0" style="font-size:14px;padding:8px 16px;"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                    }
                    else if (Model.Status == 1)
                    {
                        <span class="badge-admin order-status-1" style="font-size:14px;padding:8px 16px;"><i class="bi bi-truck"></i> Đang giao hàng</span>
                    }
                    else
                    {
                        <span class="badge-admin order-status-2" style="font-size:14px;padding:8px 16px;"><i class="bi bi-check-circle-fill"></i> Đã hoàn thành</span>
                    }
                </div>
            </div>
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="form-group-admin">
                    <label class="form-label-admin">Chuyển sang trạng thái</label>
                    <select name="status" class="form-control-admin">
                        @if (Model.Status == 0)
                        {
                            <option value="0" selected>⏳ Chờ duyệt</option>
                            <option value="1">🚚 Đang giao hàng</option>
                            <option value="2">✅ Đã hoàn thành</option>
                        }
                        else if (Model.Status == 1)
                        {
                            <option value="0">⏳ Chờ duyệt</option>
                            <option value="1" selected>🚚 Đang giao hàng</option>
                            <option value="2">✅ Đã hoàn thành</option>
                        }
                        else
                        {
                            <option value="0">⏳ Chờ duyệt</option>
                            <option value="1">🚚 Đang giao hàng</option>
                            <option value="2" selected>✅ Đã hoàn thành</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn-sport btn-primary-sport" style="width:100%;justify-content:center;margin-top:4px;">
                    <i class="bi bi-arrow-repeat"></i> Cập nhật trạng thái
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Order items -->
<div class="data-card">
    <div class="data-card-header">
        <div class="data-card-title">
            <span class="title-icon"><i class="bi bi-list-ul"></i></span>
            Danh sách sản phẩm đặt mua
        </div>
        <div class="price-text" style="font-size:18px;">
            Tổng: @totalAmount.ToString("N0") ₫
        </div>
    </div>
    <div style="overflow-x:auto;">
        @if (Model.OrderDetails != null && Model.OrderDetails.Any())
        {
            <table class="order-items-table">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Sản phẩm</th>
                        <th>Hình ảnh</th>
                        <th style="text-align:right;">Đơn giá</th>
                        <th style="text-align:center;">Số lượng</th>
                        <th style="text-align:right;">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{int stt = 1;}
                    @foreach (var item in Model.OrderDetails)
                    {
                        decimal lineTotal = item.Quantity * item.UnitPrice;
                        <tr>
                            <td style="color:var(--text-muted);">@(stt++)</td>
                            <td style="color:var(--text-primary);font-weight:600;">
                                @(item.Product?.Name ?? "Sản phẩm đã xóa")
                            </td>
                            <td>
                                @if (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl))
                                {
                                    <img src="@item.Product.ImageUrl" alt="Product"
                                         style="width:44px;height:44px;object-fit:cover;border-radius:6px;border:1px solid var(--border);" />
                                }
                                else
                                {
                                    <div style="width:44px;height:44px;border-radius:6px;background:var(--bg-input);border:1px dashed var(--border);display:flex;align-items:center;justify-content:center;color:var(--text-muted);">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td style="text-align:right;" class="price-text">@item.UnitPrice.ToString("N0") ₫</td>
                            <td style="text-align:center;">
                                <span class="badge-admin badge-primary">x @item.Quantity</span>
                            </td>
                            <td style="text-align:right;" class="price-text">@lineTotal.ToString("N0") ₫</td>
                        </tr>
                    }
                    <tr class="order-total-row">
                        <td colspan="5" style="text-align:right;font-weight:700;color:var(--text-secondary);font-size:13px;">
                            TỔNG THANH TOÁN
                        </td>
                        <td style="text-align:right;" class="price-text" style="font-size:18px;">
                            @totalAmount.ToString("N0") ₫
                        </td>
                    </tr>
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <span class="empty-state-icon">📭</span>
                <div class="empty-state-title">Đơn hàng không có sản phẩm</div>
            </div>
        }
    </div>
</div>
