@model IEnumerable<CMS.Data.Entities.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    int pending    = Model.Count(o => o.Status == 0);
    int delivering = Model.Count(o => o.Status == 1);
    int done       = Model.Count(o => o.Status == 2);
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">📦 Quản Lý Đơn Hàng</h1>
        <p class="page-subtitle">Theo dõi và xử lý tất cả đơn hàng</p>
    </div>
</div>

<!-- Mini stats -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);padding:18px;display:flex;align-items:center;gap:14px;border-bottom:3px solid var(--warning);">
        <div style="font-size:28px;">⏳</div>
        <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:var(--warning);">@pending</div>
            <div style="font-size:12px;color:var(--text-muted);">Chờ duyệt</div>
        </div>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);padding:18px;display:flex;align-items:center;gap:14px;border-bottom:3px solid var(--accent);">
        <div style="font-size:28px;">🚚</div>
        <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:var(--accent);">@delivering</div>
            <div style="font-size:12px;color:var(--text-muted);">Đang giao</div>
        </div>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);padding:18px;display:flex;align-items:center;gap:14px;border-bottom:3px solid var(--success);">
        <div style="font-size:28px;">✅</div>
        <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:var(--success);">@done</div>
            <div style="font-size:12px;color:var(--text-muted);">Đã hoàn thành</div>
        </div>
    </div>
</div>

<div class="data-card">
    <div class="data-card-header">
        <div class="data-card-title">
            <span class="title-icon"><i class="bi bi-bag-check"></i></span>
            Tất cả đơn hàng
            <span class="badge-admin badge-primary" style="margin-left:6px;">@Model.Count() đơn</span>
        </div>
    </div>
    <div style="overflow-x:auto;">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <span class="empty-state-icon">📭</span>
                <div class="empty-state-title">Chưa có đơn hàng nào</div>
                <div class="empty-state-text">Đơn hàng từ khách hàng sẽ xuất hiện tại đây</div>
            </div>
        }
        else
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Trạng thái</th>
                        <th>Ghi chú</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="id-pill">#@item.Id</span></td>
                            <td style="color:var(--text-primary);font-weight:600;">
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--primary),#FF9F68);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white;flex-shrink:0;">
                                        @(item.Customer?.FullName?.Substring(0,1).ToUpper() ?? "?")
                                    </div>
                                    @(item.Customer != null ? item.Customer.FullName : "Khách vãng lai")
                                </div>
                            </td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == 0)
                                {
                                    <span class="badge-admin order-status-0"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                }
                                else if (item.Status == 1)
                                {
                                    <span class="badge-admin order-status-1"><i class="bi bi-truck"></i> Đang giao</span>
                                }
                                else
                                {
                                    <span class="badge-admin order-status-2"><i class="bi bi-check-circle-fill"></i> Đã xong</span>
                                }
                            </td>
                            <td style="max-width:150px;">
                                <span style="font-size:12px;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">
                                    @(string.IsNullOrEmpty(item.Notes) ? "—" : item.Notes)
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon" style="background:var(--info-bg);color:var(--info);border:1px solid rgba(0,212,255,0.2);" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-warning-sport" title="Cập nhật trạng thái">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn-icon btn-danger-sport" title="Xóa"
                                       onclick="return confirm('Hủy và xóa đơn hàng #@item.Id?')">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
