@model IEnumerable<CMS.Data.Entities.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Đơn hàng</h6>
        <a asp-action="Create" class="btn btn-primary btn-sm">Thêm mới</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Trạng thái</th>
                        <th>Ghi chú</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@(item.Customer != null ? item.Customer.FullName : "N/A")</td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if(item.Status == 0) { <span class="badge bg-warning">Chờ duyệt</span> }
                                else if(item.Status == 1) { <span class="badge bg-info">Đang giao</span> }
                                else if(item.Status == 2) { <span class="badge bg-success">Đã xong</span> }
                                else { <span class="badge bg-secondary">Hủy</span> }
                            </td>
                            <td>@item.Notes</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?');">Xóa</a>
                                </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
