@model CMS.Data.Entities.Order
@{
    ViewData["Title"] = "Cập nhật Đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">Cập nhật Đơn hàng</h1>
    </div>
</div>

<div class="form-card mb-4">
    <div class="form-card-header">
        <h6 class="form-card-title"><i class="bi bi-cart-check text-warning"></i> Cập nhật Đơn hàng: #@Model.Id</h6>
    </div>
    <div class="form-card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div class="form-row">
                <div class="form-group-admin">
                    <label asp-for="CustomerId" class="form-label-admin">Khách hàng <span class="text-danger">*</span></label>
                    <select asp-for="CustomerId" class="form-control-admin" asp-items="ViewBag.CustomerList">
                        <option value="">-- Chọn khách hàng --</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                </div>
                <div class="form-group-admin">
                    <label asp-for="OrderDate" class="form-label-admin">Ngày đặt <span class="text-danger">*</span></label>
                    <input asp-for="OrderDate" type="datetime-local" class="form-control-admin" />
                    <span asp-validation-for="OrderDate" class="text-danger"></span>
                </div>
            </div>
            
            <div class="form-group-admin">
                <label asp-for="Status" class="form-label-admin">Trạng thái đơn hàng</label>
                <select asp-for="Status" class="form-control-admin">
                    <option value="0">Chờ duyệt</option>
                    <option value="1">Đang giao</option>
                    <option value="2">Đã xong</option>
                    <option value="3">Đã hủy</option>
                </select>
            </div>

            <div class="form-group-admin">
                <label asp-for="Notes" class="form-label-admin">Ghi chú</label>
                <textarea asp-for="Notes" class="form-control-admin" rows="3" placeholder="Nhập ghi chú đơn hàng..."></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-warning-sport">
                    <i class="bi bi-pencil-square"></i> Cập nhật Đơn hàng
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

