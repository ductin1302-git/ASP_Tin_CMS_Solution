@model CMS.Data.Entities.Post
@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">✏️ Chỉnh Sửa Bài Viết</h1>
        <p class="page-subtitle" style="max-width:500px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@Model.Title</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start;">

        <!-- Main content -->
        <div class="form-card">
            <div class="form-card-header">
                <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">✏️</div>
                <span class="form-card-title" style="font-size:14px;">Nội dung bài viết</span>
            </div>
            <div class="form-card-body">
                <div class="form-group-admin">
                    <label class="form-label-admin">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control-admin" placeholder="Nhập tiêu đề..." />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Nội dung chi tiết</label>
                    <textarea asp-for="Content" id="Content" class="form-control-admin" rows="14"
                              placeholder="Nội dung bài viết..."></textarea>
                </div>
            </div>
        </div>

        <!-- Sidebar settings -->
        <div style="display:flex;flex-direction:column;gap:16px;">
            <div class="form-card">
                <div class="form-card-header" style="padding:14px 18px;">
                    <span class="form-card-title" style="font-size:13px;">⚙️ Cài đặt</span>
                </div>
                <div class="form-card-body" style="padding:18px;">
                    <div class="form-group-admin">
                        <label class="form-label-admin">Chuyên mục</label>
                        <select asp-for="CategoryId" class="form-control-admin" asp-items="ViewBag.CategoryList">
                        </select>
                    </div>
                    <div class="form-group-admin">
                        <label class="form-label-admin">Ngày đăng</label>
                        <input asp-for="CreatedDate" type="date" class="form-control-admin" />
                    </div>
                    <div class="form-group-admin">
                        <label class="form-label-admin">Link ảnh (URL)</label>
                        <input asp-for="ImageUrl" class="form-control-admin" placeholder="https://..." />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div style="margin-bottom:12px;">
                            <img src="@Model.ImageUrl" alt="Ảnh hiện tại"
                                 style="width:100%;max-height:140px;object-fit:cover;border-radius:8px;border:1px solid var(--border);" />
                        </div>
                    }

                    <div class="form-group-admin">
                        <label class="form-label-admin">Upload ảnh mới</label>
                        <input type="file" name="uploadImage" class="form-control-admin" accept="image/*"
                               style="padding:8px 14px;cursor:pointer;" />
                    </div>

                    <button type="submit" class="btn-sport btn-warning-sport" style="width:100%;justify-content:center;margin-top:4px;">
                        <i class="bi bi-check-lg"></i> Cập nhật bài viết
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Content'), {
                ckfinder: {
                    uploadUrl: '/Post/UploadImage'
                }
            })
            .catch(error => { console.error(error); });
    </script>
}

