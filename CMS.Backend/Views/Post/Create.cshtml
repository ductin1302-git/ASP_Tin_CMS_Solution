@model CMS.Data.Entities.Post
@{
    ViewData["Title"] = "Viết bài mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">✍️ Viết Bài Mới</h1>
        <p class="page-subtitle">Đăng tin tức thể thao mới</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start;">

        <!-- Main content -->
        <div class="form-card">
            <div class="form-card-header">
                <div class="brand-icon" style="width:32px;height:32px;font-size:14px;">📝</div>
                <span class="form-card-title" style="font-size:14px;">Nội dung bài viết</span>
            </div>
            <div class="form-card-body">
                <div class="form-group-admin">
                    <label class="form-label-admin">Tiêu đề bài viết <span style="color:var(--danger)">*</span></label>
                    <input asp-for="Title" class="form-control-admin" placeholder="Nhập tiêu đề hấp dẫn..." />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Nội dung chi tiết</label>
                    <textarea asp-for="Content" id="Content" class="form-control-admin" rows="12"
                              placeholder="Viết nội dung bài viết tại đây..."></textarea>
                </div>
            </div>
        </div>

        <!-- Sidebar settings -->
        <div style="display:flex;flex-direction:column;gap:16px;">
            <div class="form-card">
                <div class="form-card-header" style="padding:14px 18px;">
                    <span class="form-card-title" style="font-size:13px;">⚙️ Cài đặt bài viết</span>
                </div>
                <div class="form-card-body" style="padding:18px;">
                    <div class="form-group-admin">
                        <label class="form-label-admin">Chuyên mục <span style="color:var(--danger)">*</span></label>
                        <select asp-for="CategoryId" class="form-control-admin" asp-items="ViewBag.CategoryList">
                            <option value="">-- Chọn chuyên mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="field-validation-error"></span>
                    </div>

                    <div class="form-group-admin">
                        <label class="form-label-admin">Ngày đăng</label>
                        <input asp-for="CreatedDate" type="date" class="form-control-admin"
                               value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="form-group-admin">
                        <label class="form-label-admin">Link ảnh đại diện (URL)</label>
                        <input asp-for="ImageUrl" class="form-control-admin" placeholder="https://..." />
                    </div>

                    <div class="form-group-admin">
                        <label class="form-label-admin">Hoặc upload ảnh</label>
                        <input type="file" name="uploadImage" class="form-control-admin" accept="image/*"
                               style="padding:8px 14px;cursor:pointer;" />
                    </div>

                    <div style="margin-top:8px;">
                        <button type="submit" class="btn-sport btn-primary-sport" style="width:100%;justify-content:center;">
                            <i class="bi bi-cloud-arrow-up"></i> Đăng bài
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Content'), {
                ckfinder: {
                    uploadUrl: '/Post/UploadImage'
                }
            })
            .then(editor => {
                // Custom dark mode styles for CKEditor
                editor.editing.view.change(writer => {
                    writer.setStyle('background', 'var(--bg-input)', editor.editing.view.document.getRoot());
                    writer.setStyle('color', 'var(--text-primary)', editor.editing.view.document.getRoot());
                });
            })
            .catch(error => {
                console.error(error);
            });
    </script>
}

