@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="text-primary mb-3">@Model.Title</h1>
            <p class="text-muted">
                <span class="badge bg-info text-dark me-2">@Model.Category?.Name</span>
                Ngày đăng: @Model.CreatedDate.ToString("dd/MM/yyyy")
            </p>
            <hr />
            <div class="text-center mb-4">
                <img src="@Model.ImageUrl" class="img-fluid rounded" alt="Thumbnail" />
            </div>
            <div class="content" style="font-size: 1.1rem; line-height: 1.6;">
                @Model.Content
            </div>
            
            <div class="mt-5">
                <a asp-action="Index" class="btn btn-secondary">&larr; Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>
