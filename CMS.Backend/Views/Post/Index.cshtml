@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@model X.PagedList.IPagedList<CMS.Data.Entities.Post>
@{
    ViewData["Title"] = "Bài viết & Tin tức";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">📰 Bài Viết & Tin Tức</h1>
        <p class="page-subtitle">Quản lý nội dung tin tức thể thao</p>
    </div>
    <a asp-action="Create" class="btn-sport btn-primary-sport">
        <i class="bi bi-pencil-square"></i> Viết bài mới
    </a>
</div>

@if (!Model.Any())
{
    <div class="data-card">
        <div class="empty-state">
            <span class="empty-state-icon">📝</span>
            <div class="empty-state-title">Chưa có bài viết nào</div>
            <div class="empty-state-text">Hãy đăng bài viết đầu tiên cho website của bạn</div>
            <a asp-action="Create" class="btn-sport btn-primary-sport" style="margin-top:16px;display:inline-flex;">
                <i class="bi bi-pencil-square"></i> Viết bài ngay
            </a>
        </div>
    </div>
}
else
{
    <!-- Post cards grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:18px;">
        @foreach (var item in Model)
        {
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;transition:var(--transition);animation:fadeSlideUp 0.4s ease forwards;opacity:0;"
                 onmouseenter="this.style.transform='translateY(-4px)';this.style.borderColor='rgba(255,107,53,0.25)';this.style.boxShadow='0 8px 30px rgba(0,0,0,0.4)'"
                 onmouseleave="this.style.transform='';this.style.borderColor='';this.style.boxShadow=''">
                <!-- Post image -->
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" alt="@item.Title"
                         style="width:100%;height:180px;object-fit:cover;display:block;" />
                }
                else
                {
                    <div style="width:100%;height:180px;background:var(--bg-input);display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:40px;">
                        📰
                    </div>
                }
                <!-- Post content -->
                <div style="padding:18px;">
                    <div style="margin-bottom:8px;">
                        <span class="badge-admin badge-primary">
                            <i class="bi bi-folder2"></i>
                            @(item.Category?.Name ?? "Chưa phân loại")
                        </span>
                    </div>
                    <h3 style="font-size:15px;font-weight:700;color:var(--text-primary);margin-bottom:6px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                        @item.Title
                    </h3>
                    <div style="font-size:12px;color:var(--text-muted);margin-bottom:14px;">
                        <i class="bi bi-calendar3"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                    </div>
                    <div style="display:flex;gap:8px;">
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn-sport btn-sm-sport btn-secondary-sport" style="flex:1;justify-content:center;">
                            <i class="bi bi-eye"></i> Xem
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn-sport btn-sm-sport btn-warning-sport">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn-sport btn-sm-sport btn-danger-sport"
                           onclick="return confirm('Xóa bài viết «@item.Title»?')">
                            <i class="bi bi-trash3"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="pagination-container" style="margin-top:20px; display:flex; justify-content:center;">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions {
            LiElementClasses = new string[] { "page-item" },
            PageClasses = new string[] { "page-link" }
        })
    </div>
}

