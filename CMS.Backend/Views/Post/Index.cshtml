@model IEnumerable<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Danh Sách Bài Viết";
}

<div class="container mt-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-danger fw-bold mb-1">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>
            <p class="text-muted small">Cập nhật những tin tức, kiến thức công nghệ và lộ trình học tập bổ ích nhất</p>
        </div>
        <button class="btn btn-danger btn-sm px-3 rounded-pill shadow-sm">+ Viết bài mới</button>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden transition-hover">
                    <div class="position-relative">
                        <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 200px; object-fit: cover;">
                        <span class="position-absolute top-0 end-0 bg-danger text-white fs-xs px-2.5 py-1 m-3 rounded-pill">
                            New
                        </span>
                    </div>
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold text-dark mb-2 lh-base">
                            <a href="/Post/Details/@item.Id" class="text-decoration-none text-dark hover-primary">@item.Title</a>
                        </h5>
                        <p class="card-text text-muted flex-grow-1 fs-sm mb-3 text-truncate-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                            @item.Content
                        </p>
                        <hr class="text-black-50 my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">📅 @item.CreatedDate.ToString("dd/MM/yyyy")</span>
                            <a href="/Post/Details/@item.Id" class="btn btn-outline-danger btn-sm rounded-pill px-3">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
