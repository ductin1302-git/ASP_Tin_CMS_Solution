@model CMS.Data.Entities.Product
@{
    ViewData["Title"] = "Cập nhật sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">✏️ Cập Nhật Sản Phẩm</h1>
        <p class="page-subtitle">@Model.Name</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />

    <div class="form-card">
        <div class="form-card-header">
            <div class="brand-icon" style="width:36px;height:36px;font-size:16px;">✏️</div>
            <span class="form-card-title">Cập nhật thông tin</span>
        </div>
        <div class="form-card-body">

            <div class="form-section-title">Thông tin cơ bản</div>

            <div class="form-group-admin">
                <label class="form-label-admin">Tên sản phẩm <span style="color:var(--danger)">*</span></label>
                <input asp-for="Name" class="form-control-admin" placeholder="Tên sản phẩm..." />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group-admin">
                <label class="form-label-admin">Danh mục sản phẩm <span style="color:var(--danger)">*</span></label>
                <select asp-for="CategoryProductId" class="form-control-admin" asp-items="ViewBag.CategoryList">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryProductId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Giá bán (VNĐ) <span style="color:var(--danger)">*</span></label>
                    <input asp-for="Price" type="number" class="form-control-admin" min="0" />
                    <span asp-validation-for="Price" class="field-validation-error"></span>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Số lượng tồn kho</label>
                    <input asp-for="StockQuantity" type="number" class="form-control-admin" min="0" />
                    <span asp-validation-for="StockQuantity" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-section-title" style="margin-top:24px;">Hình ảnh & mô tả</div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="form-group-admin">
                    <label class="form-label-admin">Ảnh hiện tại</label>
                    <div style="display:flex;align-items:center;gap:16px;padding:14px;background:var(--bg-input);border-radius:var(--radius-sm);border:1px solid var(--border);">
                        <img src="@Model.ImageUrl" alt="@Model.Name"
                             style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid var(--border);" />
                        <div>
                            <div style="font-size:13px;font-weight:600;color:var(--text-primary);">Ảnh hiện tại</div>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:3px;">Chọn file mới bên dưới để thay đổi</div>
                        </div>
                    </div>
                </div>
            }

            <div class="form-group-admin">
                <label class="form-label-admin">Thay đổi hình ảnh</label>
                <input type="file" name="uploadImage" class="form-control-admin" accept="image/*"
                       style="padding:8px 14px;cursor:pointer;" />
                <div style="font-size:11px;color:var(--text-muted);margin-top:6px;">
                    <i class="bi bi-info-circle"></i> Để trống nếu không muốn thay đổi ảnh
                </div>
            </div>

            <div class="form-group-admin">
                <label class="form-label-admin">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control-admin" rows="4"
                          placeholder="Nhập mô tả chi tiết..."></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-warning-sport">
                    <i class="bi bi-check-lg"></i> Cập nhật sản phẩm
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>
