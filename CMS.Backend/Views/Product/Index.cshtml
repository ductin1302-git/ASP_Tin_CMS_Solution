@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@model X.PagedList.IPagedList<CMS.Data.Entities.Product>
@{
    ViewData["Title"] = "Sản phẩm thể thao";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">🏅 Sản Phẩm Thể Thao</h1>
        <p class="page-subtitle">Quản lý toàn bộ sản phẩm trong cửa hàng</p>
    </div>
    <div style="display:flex;gap:12px;align-items:center;">
        <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;">
            <input type="file" name="file" accept=".xlsx" required style="font-size:12px;padding:4px;" />
            <button type="submit" class="btn-sport btn-sm-sport" style="background:#10b981;color:white;border:none;">
                <i class="bi bi-file-earmark-arrow-up"></i> Import Excel
            </button>
        </form>
        <a asp-action="Trash" class="btn-sport" style="background:#ef4444;color:white;">
            <i class="bi bi-trash"></i> Thùng rác
        </a>
        <a asp-action="Create" class="btn-sport btn-primary-sport">
            <i class="bi bi-plus-lg"></i> Thêm sản phẩm
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="background:#d1fae5;color:#065f46;padding:12px;border-radius:6px;margin-bottom:16px;">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" style="background:#fee2e2;color:#991b1b;padding:12px;border-radius:6px;margin-bottom:16px;">
        @TempData["Error"]
    </div>
}

<div class="data-card">
    <div class="data-card-header">
        <div class="data-card-title">
            <span class="title-icon"><i class="bi bi-box-seam"></i></span>
            Danh sách sản phẩm
            <span class="badge-admin badge-primary" style="margin-left:6px;">@Model.TotalItemCount sản phẩm</span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="empty-state-icon">📦</span>
            <div class="empty-state-title">Chưa có sản phẩm nào</div>
            <div class="empty-state-text">Hãy thêm sản phẩm thể thao đầu tiên của bạn</div>
            <a asp-action="Create" class="btn-sport btn-primary-sport" style="margin-top:16px;display:inline-flex;">
                <i class="bi bi-plus-lg"></i> Thêm ngay
            </a>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th>Tồn kho</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        int fillPct = Math.Min(100, item.StockQuantity * 5);
                        string fillClass = item.StockQuantity <= 3 ? "critical" : (item.StockQuantity <= 8 ? "low" : "");
                        <tr>
                            <td><span class="id-pill">#@item.Id</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" class="tbl-img" />
                                }
                                else
                                {
                                    <div class="tbl-img-placeholder"><i class="bi bi-image"></i></div>
                                }
                            </td>
                            <td style="color:var(--text-primary);font-weight:600;max-width:200px;">
                                <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@item.Name</div>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <div style="font-size:11px;color:var(--text-muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @item.Description
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="badge-admin badge-info">
                                    <i class="bi bi-tags"></i>
                                    @(item.CategoryProduct != null ? item.CategoryProduct.Name : "Chưa chọn")
                                </span>
                            </td>
                            <td class="price-text">@item.Price.ToString("N0") ₫</td>
                            <td>
                                <div class="stock-indicator">
                                    <div class="stock-bar">
                                        <div class="stock-fill @fillClass" style="width:@fillPct%"></div>
                                    </div>
                                    <span style="color:@(item.StockQuantity <= 3 ? "var(--danger)" : item.StockQuantity <= 8 ? "var(--warning)" : "var(--success)")">
                                        @item.StockQuantity
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-warning-sport" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa tạm sản phẩm «@item.Name»?');" style="display:inline;">
                                        <button type="submit" class="btn-icon btn-danger-sport" title="Xóa tạm" style="border:none;">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-container" style="margin-top:20px; display:flex; justify-content:center;">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions {
                LiElementClasses = new string[] { "page-item" },
                PageClasses = new string[] { "page-link" }
            })
        </div>
    }
</div>
