@model CMS.Data.Entities.Product
@{
    ViewData["Title"] = "Thêm sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-header">
    <div class="page-title-group">
        <h1 class="page-title">➕ Thêm Sản Phẩm Mới</h1>
        <p class="page-subtitle">Điền thông tin sản phẩm thể thao mới</p>
    </div>
    <a asp-action="Index" class="btn-sport btn-secondary-sport">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="form-card">
        <div class="form-card-header">
            <div class="brand-icon" style="width:36px;height:36px;font-size:16px;">🏅</div>
            <span class="form-card-title">Thông tin sản phẩm</span>
        </div>
        <div class="form-card-body">

            <div class="form-section-title">Thông tin cơ bản</div>

            <div class="form-group-admin">
                <label class="form-label-admin">Tên sản phẩm <span style="color:var(--danger)">*</span></label>
                <input asp-for="Name" class="form-control-admin" placeholder="VD: Giày chạy bộ Nike Air Zoom..." />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group-admin">
                <label class="form-label-admin">Danh mục sản phẩm <span style="color:var(--danger)">*</span></label>
                <select asp-for="CategoryProductId" class="form-control-admin" asp-items="ViewBag.CategoryList">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryProductId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group-admin">
                    <label class="form-label-admin">Giá bán (VNĐ) <span style="color:var(--danger)">*</span></label>
                    <input asp-for="Price" type="number" class="form-control-admin" min="0" placeholder="0" />
                    <span asp-validation-for="Price" class="field-validation-error"></span>
                </div>
                <div class="form-group-admin">
                    <label class="form-label-admin">Số lượng tồn kho <span style="color:var(--danger)">*</span></label>
                    <input asp-for="StockQuantity" type="number" class="form-control-admin" min="0" placeholder="0" />
                    <span asp-validation-for="StockQuantity" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-section-title" style="margin-top:24px;">Hình ảnh & mô tả</div>

            <div class="form-group-admin">
                <label class="form-label-admin">Hình ảnh sản phẩm</label>
                <input type="file" name="uploadImage" class="form-control-admin" accept="image/*"
                       style="padding:8px 14px;cursor:pointer;" />
                <div style="font-size:11px;color:var(--text-muted);margin-top:6px;">
                    <i class="bi bi-info-circle"></i> Hỗ trợ JPG, PNG, WEBP — tối đa 5MB
                </div>
            </div>

            <div class="form-group-admin">
                <label class="form-label-admin">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control-admin" rows="4"
                          placeholder="Nhập mô tả chi tiết về sản phẩm..."></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sport btn-primary-sport">
                    <i class="bi bi-check-lg"></i> Lưu sản phẩm
                </button>
                <a asp-action="Index" class="btn-sport btn-secondary-sport">
                    <i class="bi bi-x-lg"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>
